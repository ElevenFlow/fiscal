{
  "name": "@nexo/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:rls": "vitest run tests/rls-regression.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "cross-env DATABASE_URL=$DATABASE_ADMIN_URL prisma migrate deploy",
    "db:migrate:dev": "cross-env DATABASE_URL=$DATABASE_ADMIN_URL prisma migrate dev",
    "db:reset": "cross-env DATABASE_URL=$DATABASE_ADMIN_URL prisma migrate reset --force",
    "db:seed": "cross-env DATABASE_URL=$DATABASE_ADMIN_URL tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.709.0",
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/s3-request-presigner": "^3.709.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nexo/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.56.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "@opentelemetry/sdk-trace-node": "^1.29.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^8.47.0",
    "fastify": "^5.2.1",
    "nestjs-pino": "^4.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "cross-env": "^7.0.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}

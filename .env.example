# Nexo Fiscal — Environment variables (example).
# Copy to .env.local and adjust for your environment.
# NEVER commit .env or .env.local.

# ============================================================================
# Database (docker-compose postgres)
# ============================================================================
POSTGRES_DB_NAME=nexofiscal_dev
POSTGRES_ROOT_PASSWORD=postgres_root_dev
APP_USER_PASSWORD=app_user_dev_pass
APP_ADMIN_PASSWORD=app_admin_dev_pass

# Connection strings consumed by Prisma / NestJS
DATABASE_URL="postgresql://app_user:app_user_dev_pass@localhost:5434/nexofiscal_dev?schema=public&connection_limit=10"
DATABASE_ADMIN_URL="postgresql://app_admin:app_admin_dev_pass@localhost:5434/nexofiscal_dev?schema=public&connection_limit=5"

# ============================================================================
# Auth — Clerk (fill in after creating dev app at https://clerk.com)
# ============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastrar
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ============================================================================
# AWS S3 (Object Lock) — Plan 08 scaffolds, user provisions bucket
# ============================================================================
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
S3_BUCKET_FISCAL=nexofiscal-fiscal-dev
S3_BUCKET_CERTS=nexofiscal-certs-dev
# KMS CMK alias para Server-Side Encryption (ex: alias/nexofiscal-prod). Vazio em dev.
AWS_KMS_KEY_ID=
# Em prod, setar STRICT_OBJECT_LOCK=true para abortar o bootstrap caso o bucket
# fiscal NÃO tenha Object Lock COMPLIANCE com retenção >= 6 anos (FOUND-11).
STRICT_OBJECT_LOCK=false

# ============================================================================
# Observability — Sentry + OpenTelemetry (Plan 01-10 scaffold)
# Com DSN/endpoint VAZIOS, SDKs são no-op (ConsoleSpanExporter em dev).
# Produção provisiona via Secret Manager. Ver docs/OBSERVABILITY.md.
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# OTLP collector (vazio em dev → ConsoleSpanExporter; prod → ADOT/SigNoz/Grafana Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=nexofiscal-api
# STRICT_SENTRY=true aborta boot se DSN ausente em prod (atualmente no-op aviso-warning)
STRICT_SENTRY=false

# ============================================================================
# App
# ============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3333
LOG_LEVEL=debug

# ============================================================================
# Dev-only auth bypass for apps/api Tenants middleware (NEVER true in staging/prod)
# Permite headers x-tenant-id / x-role para testes antes do Clerk (Plan 07).
# ============================================================================
ALLOW_HEADER_AUTH=true
